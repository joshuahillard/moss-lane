# Moss Lane / Lazarus Engine — Environment Variables
# Copy this file to .env and fill in your values

# Solana wallet private key (base58 or JSON array format)
SOLANA_PRIVATE_KEY=your_private_key_here

# Solana RPC endpoint (Helius, QuickNode, or public)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Birdeye API key (free tier works, used for price feeds)
BIRDEYE_API_KEY=your_birdeye_key_here

# Helius API key (used for RPC and whale transaction history)
HELIUS_API_KEY=your_helius_key_here

# Paper trading mode (set to "true" for testing, "false" for live)
PAPER_TRADING=true
